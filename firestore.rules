rules_version = '2';

// Reglas MVP de VStore: acceso solo a usuarios autenticados (auth anónima incluida).
// Para probar rápido puedes usar el "Modo de prueba" de Firestore (abierto 30 días);
// cuando quieras asegurar, pega estas reglas en Firestore → Reglas y habilita
// Authentication → Anónimo.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
